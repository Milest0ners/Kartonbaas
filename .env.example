# ─── Mollie ───────────────────────────────────────────────────────────────────
# Haal je API key op via https://www.mollie.com/dashboard
MOLLIE_API_KEY=test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Publiek bereikbare URL voor de webhook (zie README voor local dev met ngrok/cloudflared)
MOLLIE_WEBHOOK_URL=https://jouwdomein.nl/api/webhook

# URL waar Mollie de klant naartoe stuurt na betaling
MOLLIE_REDIRECT_URL=https://jouwdomein.nl/bedankt

# ─── Cloudinary ───────────────────────────────────────────────────────────────
# Haal je credentials op via https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=jouw_cloud_name
CLOUDINARY_API_KEY=jouw_api_key
CLOUDINARY_API_SECRET=jouw_api_secret

# ─── E-mail via Resend (aanbevolen) ───────────────────────────────────────────
# Haal je API key op via https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_DOMAIN=kartonbaas.nl
RESEND_FROM=Kartonbaas <onboarding@resend.dev>

# ─── E-mail via SMTP (alternatief voor Resend) ────────────────────────────────
# Vul ALLEEN in als je geen RESEND_API_KEY gebruikt
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=info@kartonbaas.nl
# SMTP_PASS=jouw_wachtwoord
# SMTP_FROM=info@kartonbaas.nl

# ─── Admin ────────────────────────────────────────────────────────────────────
ADMIN_EMAIL=jij@kartonbaas.nl

# ─── Site URL ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Supabase orderopslag (aanrader) ─────────────────────────────────────────
SUPABASE_URL=https://jouw-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Wachtwoordbeveiliging voor /admin/*
ADMIN_DASHBOARD_PASSWORD=vervang_met_je_admin_wachtwoord
